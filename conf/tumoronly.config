/*
Run Dragen alignment only with no other options
*/

params {
    config_profile_name        = 'dragenflow_tumoronly_heme'
    config_profile_description = 'Dragenflow tumor only heme'

    // Set workflow
    workflow                   = "tumor"
    dbsnp                      = "/storage2/fs1/dspencer/Active/clinseq/projects/chromoseq/refdata/dragen_align_inputs/hg38/dbsnp.vcf.gz"
    snv_noisefile              = "/storage2/fs1/dspencer/Active/spencerlab/refdata/hg38/dragenfiles/IDPF_WGS_hg38_v.2.0.0_systematic_noise.snv.bed.gz"
    sv_noisefile               = "/storage2/fs1/dspencer/Active/spencerlab/refdata/hg38/dragenfiles/IDPF_WGS_hg38_v3.0.0_systematic_noise.sv.bedpe.gz"
    cnv_population_vcf         = "/storage2/fs1/dspencer/Active/clinseq/projects/chromoseq/refdata/dragen_align_inputs/hg38/1000G_phase1.snps.high_confidence.hg38.vcf.gz"
    sv_annotation_distance     = 20000
    max_filter_sv_length       = 150000000
    mark_duplicates             = true

}

// Set dragen args here. 
process {
    withName: 'DRAGEN_MULTIALIGN' {
        ext.dragen_args  = { [ "--enable-variant-caller true",
                               "--enable-sv true",
                               "--sv-output-contigs true",
                               // add lines to add/remove arguments
                               "--enable-cnv true",
                               "--cnv-enable-ref-calls false"
                             ].join(' ').trim()
                            }
    }
}
